# =============================================================================
# QREATE - AI Exam Generator Configuration
# =============================================================================
# Copy this file to .env.local and fill in your API keys

# =============================================================================
# AI PROVIDER (Together AI + Groq fallback)
# =============================================================================

# Together AI API Key (PRIMARY) - Required
# Two-pass exam generation with Qwen3-235B for high quality
# Get your key from https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Groq API Key (FALLBACK) - Optional
# Used automatically if Together AI is unavailable
# Get your free key from https://console.groq.com/keys
GROQ_API_KEY=

# =============================================================================
# QUOTA CONFIGURATION
# =============================================================================

# Production Quota Control
# Set to 'true' for development/stress testing with higher limits
# Set to 'false' to use production quotas
ENABLE_STRESS_TESTING=true

# Production User Quotas (active when ENABLE_STRESS_TESTING=false)
MAX_EXAMS_PER_WEEK=10
DAILY_BURST_LIMIT=3
MAX_EXAMS_PER_MONTH=40
MIN_QUESTIONS_PER_EXAM=10
MAX_QUESTIONS_PER_EXAM=50
RATE_LIMIT_DELAY_SECONDS=30
