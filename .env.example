# =============================================================================
# QREATE — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and never committed.

# =============================================================================
# AI PROVIDERS
# =============================================================================

# Together AI (PRIMARY — required)
# Two-pass exam generation with Qwen3-235B
# Get a key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Groq (FALLBACK — optional)
# Automatically used if Together AI is unavailable
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=

# =============================================================================
# QUOTA CONFIGURATION
# =============================================================================

# Set to 'true' for development (removes quota limits)
# Set to 'false' or omit for production quotas
ENABLE_STRESS_TESTING=false

# Production quotas (active when ENABLE_STRESS_TESTING=false)
MAX_EXAMS_PER_WEEK=10
DAILY_BURST_LIMIT=3
MAX_EXAMS_PER_MONTH=40
MIN_QUESTIONS_PER_EXAM=10
MAX_QUESTIONS_PER_EXAM=50
RATE_LIMIT_DELAY_SECONDS=30
